# Server Configuration
NODE_ENV=production
PORT=10000
HTTPS_PORT=3443

# SSL Configuration (DISABLED on Render - they provide HTTPS)
SSL_ENABLED=false
SSL_KEY_PATH=./key.pem
SSL_CERT_PATH=./cert.pem
SSL_REDIRECT_HTTP=false

# Security Keys (Render will auto-generate these)
JWT_SECRET=your_jwt_secret_here
SESSION_SECRET=your_session_secret_here
ENCRYPTION_KEY=your_encryption_key_here

# Database Path (Render persistent disk)
DB_PATH=/opt/render/project/data/school.db

# Default Admin Password (for initial setup)
DEFAULT_ADMIN_PASSWORD=admin@321

# Email Configuration (Optional - for OTP emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Razorpay Configuration (Optional - for payments)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Domain and CORS Configuration (for Render)
ALLOWED_DOMAINS=localhost,127.0.0.1,.onrender.com,render.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,https://*.onrender.com

# Email Alerts (set to true to enable OTP emails)
EMAIL_ALERTS_ENABLED=false
